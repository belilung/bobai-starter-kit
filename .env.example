# Copy this file to .env and fill in your token:   cp .env.example .env
#
# LinkedIn access token used by tools/post_to_linkedin.py to publish posts.
# It MUST come from a LinkedIn app with the "Share on LinkedIn" product enabled
# and the w_member_social scope. A "Sign In with LinkedIn" (OIDC) token will not
# work for posting. See README.md section 4 for the full walkthrough.
LINKEDIN_TOKEN=
